{
  "name": "@gadagi/auth",
  "version": "1.0.6",
  "description": "Authentication utilities for gadagi micro-frontends",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json --emitDeclarationOnly && webpack --mode production",
    "dev": "webpack --mode development --watch",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly",
    "build:js": "webpack --mode production",
    "build:prod": "tsc -p tsconfig.build.json --emitDeclarationOnly && webpack --mode production --stats-error-details",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.0.0"
  },
  "dependencies": {
    "@gadagi/design-system": "^1.0.6",
    "@gadagi/types": "^1.0.2"
  },
  "devDependencies": {
    "@gadagi/design-system": "^1.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.0.0",
    "ts-loader": "^9.0.0",
    "typescript": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0",
    "css-loader": "^7.0.0",
    "style-loader": "^4.0.0"
  }
}
